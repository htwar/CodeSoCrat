# Backend
CODESOCRAT_DATABASE_URL=sqlite:///./codesocrat.db
# Use a long random value. Rotate by moving the previous key into
# CODESOCRAT_SECRET_KEY_PREVIOUS before deploying the new current key.
CODESOCRAT_SECRET_KEY_CURRENT=change-me-to-a-long-random-secret
CODESOCRAT_SECRET_KEY_PREVIOUS=
CODESOCRAT_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CODESOCRAT_DOCKER_IMAGE=python:3.11-alpine
CODESOCRAT_DOCKER_AUTO_PULL=true
CODESOCRAT_DOCKER_PULL_TIMEOUT_SECONDS=120
CODESOCRAT_OLLAMA_BASE_URL=http://127.0.0.1:11434
CODESOCRAT_OLLAMA_MODEL=qwen2.5-coder:14b
CODESOCRAT_RATE_LIMIT_WINDOW_SECONDS=60
CODESOCRAT_RATE_LIMIT_IP_PUBLIC=60
CODESOCRAT_RATE_LIMIT_IP_AUTHENTICATED=120
CODESOCRAT_RATE_LIMIT_USER_AUTHENTICATED=90
CODESOCRAT_LOGIN_RATE_LIMIT_IP=10
CODESOCRAT_LOGIN_RATE_LIMIT_USER=5
